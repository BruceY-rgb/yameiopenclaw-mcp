# ─────────────────────────────────────────────────────────────────
# 腾云商旅 MCP Server（小龙虾 openclaw）配置示例
# 复制本文件为 .env 并填写实际值
# ─────────────────────────────────────────────────────────────────

# ── 公司密钥（必填）────────────────────────────────────────────────
# 由运营后台创建公司后分配，用于调用开放接口（创建用户账号）
ONTUOTU_APP_KEY=your_app_key_here
ONTUOTU_APP_SECRET=your_app_secret_here

# ── API 地址（可选，默认 https://sla.ontuotu.com）─────────────────
# ONTUOTU_BASE_URL=https://sla.ontuotu.com

# ── MCP 传输模式（可选）──────────────────────────────────────────
# stdio  适合 Claude Desktop 本地调用（默认）
# http   适合远程部署
# sse    适合实时推送场景
MCP_TRANSPORT=stdio

# ── HTTP 模式监听端口（MCP_TRANSPORT=http 时生效）────────────────
MCP_PORT=8000

# ── 请求配置（可选）──────────────────────────────────────────────
REQUEST_TIMEOUT=30.0
MAX_RETRIES=3

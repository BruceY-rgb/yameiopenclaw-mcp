# 美亚航旅API MCP Server 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===========================================
# 美亚航旅API配置 (必填)
# ===========================================

# API基础URL
MEIYA_API_URL=https://api.meiya.com

# API用户名（签约后获取）
MEIYA_USERNAME=admin

# API密码（签约后获取，需保密）
MEIYA_PASSWORD=test123456

# ===========================================
# MCP Server配置
# ===========================================

# 传输模式: stdio (本地) / http / sse
MCP_TRANSPORT=stdio

# HTTP端口（当MCP_TRANSPORT为http或sse时生效）
MCP_PORT=8000

# ===========================================
# 用户认证配置（可选）
# ===========================================

# 子用户ID（用于用户级别认证）
# USER_ID=your_user_id
# USER_PASSWORD=your_user_password

# ===========================================
# 日志配置
# ===========================================

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 日志格式: json / console
LOG_FORMAT=console

# ===========================================
# 可选配置
# ===========================================

# 请求超时时间（秒）
REQUEST_TIMEOUT=30

# 最大重试次数
MAX_RETRIES=3

# Token缓存时间（秒，默认2小时）
TOKEN_CACHE_DURATION=7200
